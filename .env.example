TRANSPORT=stdio
PORT=3000

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=m3
MINIMAX_RPM=60
MINIMAX_TPM=100000
MINIMAX_DAILY_TOKENS=1000000
MINIMAX_COOLDOWN_SECONDS=60

SYNTHETICNEW_API_KEY=
SYNTHETICNEW_BASE_URL=https://api.synthetic.new/v1
SYNTHETICNEW_MODEL=glm-5.2
SYNTHETICNEW_RPM=60
SYNTHETICNEW_TPM=100000
SYNTHETICNEW_DAILY_TOKENS=1000000
SYNTHETICNEW_COOLDOWN_SECONDS=60

ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-4.7
ZAI_RPM=60
ZAI_TPM=100000
ZAI_DAILY_TOKENS=1000000
ZAI_COOLDOWN_SECONDS=60

# grok via the Hermes OAuth proxy (spot-tech-ci) over the local grok-hermes-tunnel.
# No secret: the proxy mints the SuperGrok bearer itself. All values below are
# defaulted in code, so you can leave this block empty for local stdio use.
# Selectable explicitly (provider_preference: "grok"); excluded from the "auto"
# rotation. For a containerized deploy, point GROK_BASE_URL at the host tunnel.
GROK_API_KEY=hermes
GROK_BASE_URL=http://127.0.0.1:8649/v1
GROK_MODEL=grok-4.20-0309-non-reasoning
GROK_RPM=60
GROK_TPM=100000
GROK_DAILY_TOKENS=1000000
GROK_COOLDOWN_SECONDS=60

DEFAULT_PROVIDER=auto
PERSIST_USAGE=false
